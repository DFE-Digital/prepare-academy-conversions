{
    "name": "prepare-academy-conversions-cypress-tests",
    "version": "1.0.0",
    "description": "Automated regression tests for the DfE Prepare conversions journeys",
    "main": "index.js",
    "testFiles": "**/*.{js,ts}",
    "scripts": {
        "cy:open": "cypress open --browser edge",
        "cy:run": "npm run clean:reports && cypress run --browser edge",
        "cy:run:conversions": "npm run cy:run -- --spec \"cypress/e2e/conversions/**\"",
        "cy:run:transfers": "npm run cy:run -- --spec \"cypress/e2e/transfers/**\"",
        "cy:zap": "npm run clean:reports && cypress run --browser electron",
        "cy:notify": "cypress-slack-reporter",
        "clean:reports": "rimraf cypress/reports/mocha/",
        "combine:reports": "mochawesome-merge cypress/reports/mocha/*.json > mochareports/report.json",
        "create:html:report": "marge mochareports/report.json -f report -o mochareports",
        "generate:html:report": "npm run combine:reports && npm run create:html:report",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier:check": "prettier . --check",
        "prettier:write": "prettier . --write",
        "format": "npm run prettier:write && npm run lint",
        "format:check": "npm run prettier:check && npm run lint"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DFE-Digital/prepare-academy-conversions.git"
    },
    "keywords": [
        "regression",
        "cypress",
        "testing"
    ],
    "contributors": [
        {
            "name": "Mike Dally"
        },
        {
            "name": "Lisa Sau"
        },
        {
            "name": "Chris Sherlock"
        },
        {
            "name": "Daniel Good"
        },
        {
            "name": "Dom Need"
        },
        {
            "name": "Fahad Darwish"
        },
        {
            "name": "Paddy Clark"
        }
    ],
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/DFE-Digital/prepare-academy-conversions/issues"
    },
    "homepage": "https://github.com/DFE-Digital/prepare-academy-conversions#readme",
    "devDependencies": {
        "@cypress/grep": "6.0.0",
        "@cypress/webpack-preprocessor": "7.0.2",
        "@types/jest": "^30.0.0",
        "@types/node": "25.5.0",
        "@typescript-eslint/parser": "^8.57.1",
        "axe-core": "4.11.1",
        "cy-verify-downloads": "0.3.0",
        "cypress": "15.12.0",
        "cypress-axe": "1.7.0",
        "cypress-downloadfile": "1.2.4",
        "cypress-file-upload": "5.0.8",
        "cypress-localstorage-commands": "2.3.0",
        "cypress-multi-reporters": "2.0.5",
        "cypress-slack-reporter": "1.5.4",
        "dayjs": "1.11.20",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-cypress": "^6.2.0",
        "eslint-plugin-prettier": "^5.5.5",
        "mochawesome": "7.1.4",
        "prettier": "3.8.1",
        "typescript": "5.9.3",
        "zaproxy": "2.0.0-rc.7"
    },
    "author": ""
}
